{
  "description": "Aria Memory Codex lifecycle hooks - startup context, deferred wrapup marker, and compaction tracking",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ARIA_MEMORY_RUNTIME=codex bash ${CODEX_PLUGIN_ROOT:-.}/hooks/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ARIA_MEMORY_RUNTIME=codex bash ${CODEX_PLUGIN_ROOT:-.}/hooks/session-end.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ARIA_MEMORY_RUNTIME=codex bash ${CODEX_PLUGIN_ROOT:-.}/hooks/pre-compact.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
